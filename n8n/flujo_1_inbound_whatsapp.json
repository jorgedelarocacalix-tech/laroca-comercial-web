      "name": "Limpiar Telefono JS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 300],
      "parameters": {
        "jsCode": "let rawPhone = $input.item.json.body?.From || $input.item.json.From || '';\nlet cleanPhone = rawPhone.replace('whatsapp:', '').trim();\nif (!cleanPhone.startsWith('+')) cleanPhone = '+' + cleanPhone;\n\nconst texto = ($input.item.json.body?.Body || $input.item.json.Body || '').trim();\nconst numMedia = parseInt($input.item.json.body?.NumMedia || $input.item.json.NumMedia || '0');\nconst profileName = $input.item.json.body?.ProfileName || $input.item.json.ProfileName || 'Cliente Nuevo';\nconst mediaUrl = $input.item.json.body?.MediaUrl0 || $input.item.json.MediaUrl0 || null;\nconst mediaType = $input.item.json.body?.MediaContentType0 || $input.item.json.MediaContentType0 || null;\n\nreturn [{\n  json: {\n    telefono: cleanPhone,\n    texto,\n    numMedia,\n    esAudio: mediaType ? mediaType.startsWith('audio') : false,\n    mediaUrl,\n    mediaType,\n    nombre: profileName\n  }\n}];"
      }
    },
